<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lovetree.mapper.TreeMapper">
    <select id="findByCoupleId" resultType="com.lovetree.entity.Tree">
        SELECT * FROM tree WHERE couple_id = #{coupleId}
    </select>
</mapper>
